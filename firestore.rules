rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfilePath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function reportPath(reportId) {
      return /databases/$(database)/documents/reports/$(reportId);
    }

    function upvotePath(reportId, uid) {
      return /databases/$(database)/documents/upvotes/$(reportId + "_" + uid);
    }

    function reportLimitPath(uid, limitId) {
      return /databases/$(database)/documents/users/$(uid)/reportLimits/$(limitId);
    }

    function isSuperAdmin() {
      return userIsActive()
        && (
          request.auth.token.superAdmin == true
          || request.auth.token.role == "super-admin"
          || (
            exists(userProfilePath(request.auth.uid))
            && get(userProfilePath(request.auth.uid)).data.role == "super-admin"
          )
        );
    }

    function userIsActive() {
      return signedIn()
        && (!exists(userProfilePath(request.auth.uid))
          || get(userProfilePath(request.auth.uid)).data.disabled != true);
    }

    function validRole(role) {
      return role in ["citizen", "staff", "lgu-admin", "super-admin"];
    }

    function validOptionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function validOptionalBoolean(value) {
      return value == null || value is bool;
    }

    function validOptionalCloudinaryImageUrl(data) {
      return !data.keys().hasAny(["imageUrl"])
        || (data.imageUrl is string
          && data.imageUrl.size() <= 1500
          && data.imageUrl.matches("^https://res\\.cloudinary\\.com/dh0xm7zdj/image/upload/.*"));
    }

    function validOptionalCloudinaryPublicId(data) {
      return !data.keys().hasAny(["imagePublicId"])
        || (data.imagePublicId is string
          && data.imagePublicId.size() <= 255
          && data.imagePublicId.matches("^report-photos/" + request.auth.uid + "/[A-Za-z0-9_./-]+$"));
    }

    function validOptionalCloudinaryPhotoUrl(data) {
      return !data.keys().hasAny(["photoUrl"])
        || (data.photoUrl is string
          && data.photoUrl.size() <= 1000
          && data.photoUrl.matches("^https://res\\.cloudinary\\.com/dh0xm7zdj/image/upload/.*"));
    }

    function validOptionalCloudinaryPhotoPublicId(data) {
      return !data.keys().hasAny(["photoPublicId"])
        || (data.photoPublicId is string
          && data.photoPublicId.size() <= 255
          && data.photoPublicId.matches("^[A-Za-z0-9_./-]+$"));
    }

    function validOptionalResidenceInfo(data) {
      return !data.keys().hasAny([
          "residenceArea",
          "residenceDistrict",
          "residenceBarangay"
        ])
        || (data.keys().hasAll([
            "residenceArea",
            "residenceDistrict",
            "residenceBarangay"
          ])
          && data.residenceArea in [
            "Davao City",
            "Davao del Sur",
            "Davao Occidental",
            "Davao de Oro",
            "Davao del Norte",
            "Davao Oriental"
          ]
          && data.residenceDistrict is string
          && data.residenceDistrict.size() >= 2
          && data.residenceDistrict.size() <= 80
          && data.residenceBarangay is string
          && data.residenceBarangay.size() >= 2
          && data.residenceBarangay.size() <= 80);
    }

    function validProfile(uid) {
      return request.resource.data.keys().hasAll([
          "uid",
          "email",
          "displayName",
          "role",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "role",
          "createdAt",
          "updatedAt",
          "photoUrl",
          "photoPublicId",
          "residenceArea",
          "residenceDistrict",
          "residenceBarangay",
          "assignedArea",
          "assignedDepartment",
          "disabled",
          "disableReason"
        ])
        && request.resource.data.uid == uid
        && request.resource.data.role == "citizen"
        && validOptionalString(request.resource.data.email, 254)
        && validOptionalString(request.resource.data.displayName, 80)
        && validOptionalCloudinaryPhotoUrl(request.resource.data)
        && validOptionalCloudinaryPhotoPublicId(request.resource.data)
        && validOptionalResidenceInfo(request.resource.data)
        && validOptionalAdminUserFields(request.resource.data)
        && request.resource.data.disabled != true
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validStatus(status) {
      return status in ["submitted", "under-review", "in-progress", "resolved"];
    }

    function validCategory(category) {
      return category in [
        "pothole",
        "streetlight",
        "flooding",
        "garbage",
        "drainage",
        "illegal-dumping",
        "other"
      ];
    }

    function validDavaoRegionArea(area) {
      return area in [
        "Davao City",
        "Davao del Sur",
        "Davao Occidental",
        "Davao de Oro",
        "Davao del Norte",
          "Davao Oriental"
      ];
    }

    function validOptionalAssignedArea(data) {
      return !data.keys().hasAny(["assignedArea"])
        || data.assignedArea == ""
        || validDavaoRegionArea(data.assignedArea);
    }

    function validOptionalAdminUserFields(data) {
      return validOptionalAssignedArea(data)
        && validOptionalString(data.assignedDepartment, 80)
        && validOptionalBoolean(data.disabled)
        && validOptionalString(data.disableReason, 300);
    }

    function validOptionalReviewFlag(data) {
      return !data.keys().hasAny(["reviewFlag"])
        || data.reviewFlag in ["active", "duplicate", "spam", "invalid"];
    }

    function validOptionalAssignmentFields(data) {
      return validOptionalString(data.assignedLguId, 120)
        && validOptionalString(data.assignedDepartment, 80)
        && validOptionalString(data.assignedStaff, 120)
        && validOptionalString(data.duplicateOfReportId, 160)
        && validOptionalString(data.moderationReason, 500)
        && validOptionalString(data.responseNote, 800)
        && validOptionalString(data.slaDueAt, 40)
        && (!data.keys().hasAny(["assignedAt"]) || data.assignedAt is timestamp);
    }

    function hasPrivateReportFields(data) {
      return data.keys().hasAny([
        "assignedAt",
        "assignedDepartment",
        "assignedLguId",
        "assignedStaff",
        "duplicateOfReportId",
        "moderationReason",
        "responseNote",
        "reviewFlag",
        "slaDueAt"
      ]);
    }

    function validReportAdminData(data) {
      return data.keys().hasAll([
          "updatedAt",
          "updatedBy"
        ])
        && data.keys().hasOnly([
          "assignedAt",
          "assignedDepartment",
          "assignedLguId",
          "assignedStaff",
          "duplicateOfReportId",
          "moderationReason",
          "responseNote",
          "reviewFlag",
          "slaDueAt",
          "updatedAt",
          "updatedBy"
        ])
        && validOptionalReviewFlag(data)
        && validOptionalAssignmentFields(data)
        && data.updatedAt == request.time
        && data.updatedBy == request.auth.uid;
    }

    function validLguPlan(plan) {
      return plan in ["free-pilot", "basic", "pro", "premium"];
    }

    function validLguStatus(status) {
      return status in ["pilot", "active", "paused"];
    }

    function validLguData(data) {
      return data.keys().hasAll([
          "name",
          "area",
          "plan",
          "status",
          "adminEmail",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "name",
          "area",
          "plan",
          "status",
          "adminEmail",
          "createdAt",
          "updatedAt"
        ])
        && data.name is string
        && data.name.size() >= 2
        && data.name.size() <= 120
        && validDavaoRegionArea(data.area)
        && validLguPlan(data.plan)
        && validLguStatus(data.status)
        && validOptionalString(data.adminEmail, 254)
        && data.updatedAt == request.time;
    }

    function validSystemSettingsData(data) {
      return data.keys().hasAll([
          "allowedImageTypes",
          "blockedWords",
          "duplicateRadiusMeters",
          "maintenanceMode",
          "maxImageSizeMb",
          "pwaInstallPrompt",
          "reportLimitPerDay",
          "reportLimitPerHour",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "allowedImageTypes",
          "blockedWords",
          "duplicateRadiusMeters",
          "maintenanceMode",
          "maxImageSizeMb",
          "pwaInstallPrompt",
          "reportLimitPerDay",
          "reportLimitPerHour",
          "updatedAt"
        ])
        && data.allowedImageTypes is list
        && data.allowedImageTypes.size() >= 1
        && data.allowedImageTypes.size() <= 5
        && data.allowedImageTypes.hasOnly(["image/jpeg", "image/png", "image/webp"])
        && data.blockedWords is list
        && data.blockedWords.size() <= 50
        && data.duplicateRadiusMeters is int
        && data.duplicateRadiusMeters >= 25
        && data.duplicateRadiusMeters <= 1000
        && data.maintenanceMode is bool
        && data.maxImageSizeMb is int
        && data.maxImageSizeMb >= 1
        && data.maxImageSizeMb <= 10
        && data.pwaInstallPrompt is bool
        && data.reportLimitPerDay is int
        && data.reportLimitPerDay >= 1
        && data.reportLimitPerDay <= 100
        && data.reportLimitPerHour is int
        && data.reportLimitPerHour >= 1
        && data.reportLimitPerHour <= 20
        && data.updatedAt == request.time;
    }

    function validWorkflowSettingsData(data) {
      return data.keys().hasAll([
          "rejectionReasons",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "rejectionReasons",
          "updatedAt"
        ])
        && data.rejectionReasons is list
        && data.rejectionReasons.size() <= 25
        && data.updatedAt == request.time;
    }

    function validDavaoCoordinates(latitude, longitude) {
      return latitude is number
        && latitude >= 5.2
        && latitude <= 8.15
        && longitude is number
        && longitude >= 124.9
        && longitude <= 126.75;
    }

    function validReportLimitBase(data, uid, scope, maxReports, windowDuration) {
      return data.keys().hasAll([
          "uid",
          "scope",
          "windowStart",
          "count",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "uid",
          "scope",
          "windowStart",
          "count",
          "updatedAt"
        ])
        && data.uid == uid
        && data.scope == scope
        && data.windowStart is timestamp
        && data.windowStart <= request.time
        && data.windowStart >= request.time - windowDuration
        && data.count is int
        && data.count >= 1
        && data.count <= maxReports
        && data.updatedAt == request.time;
    }

    function validReportLimitCreate(uid, scope, maxReports, windowDuration) {
      return validReportLimitBase(request.resource.data, uid, scope, maxReports, windowDuration)
        && request.resource.data.count == 1;
    }

    function validReportLimitUpdate(uid, scope, maxReports, windowDuration) {
      return validReportLimitBase(request.resource.data, uid, scope, maxReports, windowDuration)
        && resource.data.uid == uid
        && resource.data.scope == scope
        && resource.data.windowStart is timestamp
        && resource.data.count is int
        && (
          (
            resource.data.windowStart >= request.time - windowDuration
            && request.resource.data.windowStart == resource.data.windowStart
            && request.resource.data.count == resource.data.count + 1
          )
          || (
            resource.data.windowStart < request.time - windowDuration
            && request.resource.data.count == 1
          )
        );
    }

    function validReportLimitAfterBase(uid, scope, maxReports, windowDuration) {
      return existsAfter(reportLimitPath(uid, scope))
        && validReportLimitBase(getAfter(reportLimitPath(uid, scope)).data, uid, scope, maxReports, windowDuration);
    }

    function validReportLimitAfterIncrement(uid, scope, maxReports, windowDuration) {
      return validReportLimitAfterBase(uid, scope, maxReports, windowDuration)
        && (
          (
            !exists(reportLimitPath(uid, scope))
            && getAfter(reportLimitPath(uid, scope)).data.count == 1
          )
          || (
            exists(reportLimitPath(uid, scope))
            && get(reportLimitPath(uid, scope)).data.windowStart >= request.time - windowDuration
            && getAfter(reportLimitPath(uid, scope)).data.windowStart ==
              get(reportLimitPath(uid, scope)).data.windowStart
            && getAfter(reportLimitPath(uid, scope)).data.count ==
              get(reportLimitPath(uid, scope)).data.count + 1
          )
          || (
            exists(reportLimitPath(uid, scope))
            && get(reportLimitPath(uid, scope)).data.windowStart < request.time - windowDuration
            && getAfter(reportLimitPath(uid, scope)).data.count == 1
          )
        );
    }

    function validReportCreateRateLimit() {
      return validReportLimitAfterIncrement(request.auth.uid, "hour", 5, duration.value(1, "h"))
        && validReportLimitAfterIncrement(request.auth.uid, "day", 20, duration.value(24, "h"));
    }

    function validReportData() {
      return request.resource.data.keys().hasAll([
          "title",
          "category",
          "description",
          "barangay",
          "latitude",
          "longitude",
          "status",
          "upvotes",
          "createdBy",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "title",
          "category",
          "description",
          "barangay",
          "latitude",
          "longitude",
          "status",
          "upvotes",
          "createdBy",
          "createdAt",
          "updatedAt",
          "imageUrl",
          "imagePublicId"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 5
        && request.resource.data.title.size() <= 120
        && validCategory(request.resource.data.category)
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.description.size() <= 800
        && request.resource.data.barangay is string
        && validDavaoRegionArea(request.resource.data.barangay)
        && validDavaoCoordinates(request.resource.data.latitude, request.resource.data.longitude)
        && request.resource.data.status == "submitted"
        && request.resource.data.upvotes == 0
        && request.resource.data.createdBy == request.auth.uid
        && validOptionalCloudinaryImageUrl(request.resource.data)
        && validOptionalCloudinaryPublicId(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validReportEditableFields() {
      return request.resource.data.title is string
        && request.resource.data.title.size() >= 5
        && request.resource.data.title.size() <= 120
        && validCategory(request.resource.data.category)
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.description.size() <= 800
        && request.resource.data.barangay is string
        && validDavaoRegionArea(request.resource.data.barangay)
        && validDavaoCoordinates(request.resource.data.latitude, request.resource.data.longitude)
        && request.resource.data.updatedAt == request.time
        // Immutable fields must remain unchanged (defense-in-depth alongside hasOnly diff check)
        && request.resource.data.status == resource.data.status
        && request.resource.data.upvotes == resource.data.upvotes
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validReportConfirmationCountUpdate(reportId) {
      return userIsActive()
        && resource.data.createdBy != request.auth.uid
        && !exists(upvotePath(reportId, request.auth.uid))
        && getAfter(upvotePath(reportId, request.auth.uid)).data.reportId == reportId
        && getAfter(upvotePath(reportId, request.auth.uid)).data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "upvotes",
          "updatedAt"
        ])
        && request.resource.data.upvotes == resource.data.upvotes + 1
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if signedIn()
        && request.auth.uid == uid
        && validProfile(uid);
      allow update: if (isSuperAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "role",
            "disabled",
            "assignedArea",
            "assignedDepartment",
            "displayName",
            "photoUrl",
            "photoPublicId",
            "residenceArea",
            "residenceDistrict",
            "residenceBarangay",
            "disableReason",
            "updatedAt"
          ])
          && validRole(request.resource.data.role)
          && validOptionalString(request.resource.data.displayName, 80)
          && validOptionalCloudinaryPhotoUrl(request.resource.data)
          && validOptionalCloudinaryPhotoPublicId(request.resource.data)
          && validOptionalResidenceInfo(request.resource.data)
          && validOptionalAdminUserFields(request.resource.data)
          && request.resource.data.updatedAt == request.time)
        || (signedIn()
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "displayName",
            "photoUrl",
            "photoPublicId",
            "residenceArea",
            "residenceDistrict",
            "residenceBarangay",
            "updatedAt"
          ])
          && validOptionalString(request.resource.data.displayName, 80)
          && validOptionalCloudinaryPhotoUrl(request.resource.data)
          && validOptionalCloudinaryPhotoPublicId(request.resource.data)
          && validOptionalResidenceInfo(request.resource.data)
          && request.resource.data.updatedAt == request.time);
      allow delete: if false;

      match /reportLimits/{limitId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn()
          && request.auth.uid == uid
          && (
            (limitId == "hour" && validReportLimitCreate(uid, "hour", 5, duration.value(1, "h")))
            || (limitId == "day" && validReportLimitCreate(uid, "day", 20, duration.value(24, "h")))
          );
        allow update: if signedIn()
          && request.auth.uid == uid
          && (
            (limitId == "hour" && validReportLimitUpdate(uid, "hour", 5, duration.value(1, "h")))
            || (limitId == "day" && validReportLimitUpdate(uid, "day", 20, duration.value(24, "h")))
          );
        allow delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if !hasPrivateReportFields(resource.data) || isSuperAdmin();
      allow create: if userIsActive() && validReportData() && validReportCreateRateLimit();
      allow update: if (isSuperAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status",
            "reviewFlag",
            "assignedLguId",
            "assignedDepartment",
            "assignedStaff",
            "assignedAt",
            "duplicateOfReportId",
            "moderationReason",
            "responseNote",
            "slaDueAt",
            "updatedAt"
          ])
          && !hasPrivateReportFields(request.resource.data)
          && validStatus(request.resource.data.status)
          && request.resource.data.updatedAt == request.time)
        || (userIsActive()
          && resource.data.createdBy == request.auth.uid
          && resource.data.status == "submitted"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "title",
            "category",
            "description",
            "barangay",
            "latitude",
            "longitude",
            "updatedAt"
          ])
          && validReportEditableFields())
        || validReportConfirmationCountUpdate(reportId);
      allow delete: if isSuperAdmin()
        || (userIsActive()
          && resource.data.createdBy == request.auth.uid
          && resource.data.status == "submitted");
    }

    match /reportAdmin/{reportId} {
      allow read: if isSuperAdmin();
      allow create, update: if isSuperAdmin()
        && exists(reportPath(reportId))
        && validReportAdminData(request.resource.data);
      allow delete: if false;
    }

    match /statusLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin()
        && request.resource.data.keys().hasAll([
          "reportId",
          "status",
          "updatedBy",
          "createdAt"
        ])
        && request.resource.data.keys().hasOnly([
          "reportId",
          "status",
          "note",
          "updatedBy",
          "createdAt"
        ])
        && request.resource.data.reportId is string
        && validStatus(request.resource.data.status)
        && validOptionalString(request.resource.data.note, 500)
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin()
        && request.resource.data.keys().hasAll([
          "action",
          "targetType",
          "targetId",
          "summary",
          "actorId",
          "createdAt"
        ])
        && request.resource.data.keys().hasOnly([
          "action",
          "targetType",
          "targetId",
          "summary",
          "actorId",
          "createdAt"
        ])
        && request.resource.data.action is string
        && request.resource.data.action.size() <= 80
        && request.resource.data.targetType is string
        && request.resource.data.targetType.size() <= 40
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() <= 160
        && request.resource.data.summary is string
        && request.resource.data.summary.size() <= 500
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /lgus/{lguId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSuperAdmin()
        && validLguData(request.resource.data)
        && request.resource.data.createdAt == request.time;
      allow update: if isSuperAdmin()
        && validLguData(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /adminSettings/{settingId} {
      allow read, list: if isSuperAdmin();
      allow create, update: if isSuperAdmin()
        && (
          (settingId == "system" && validSystemSettingsData(request.resource.data))
          || (settingId == "workflow" && validWorkflowSettingsData(request.resource.data))
        );
      allow delete: if false;
    }

    match /upvotes/{upvoteId} {
      allow read: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if userIsActive()
        && upvoteId == request.resource.data.reportId + "_" + request.auth.uid
        && request.resource.data.keys().hasAll([
          "reportId",
          "userId",
          "createdAt"
        ])
        && request.resource.data.keys().hasOnly([
          "reportId",
          "userId",
          "createdAt"
        ])
        && request.resource.data.reportId is string
        && exists(reportPath(request.resource.data.reportId))
        && get(reportPath(request.resource.data.reportId)).data.createdBy != request.auth.uid
        && getAfter(reportPath(request.resource.data.reportId)).data.upvotes ==
          get(reportPath(request.resource.data.reportId)).data.upvotes + 1
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
