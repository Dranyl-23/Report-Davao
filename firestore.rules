rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfilePath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function reportPath(reportId) {
      return /databases/$(database)/documents/reports/$(reportId);
    }

    function upvotePath(reportId, uid) {
      return /databases/$(database)/documents/upvotes/$(reportId + "_" + uid);
    }

    function reportLimitPath(uid, limitId) {
      return /databases/$(database)/documents/users/$(uid)/reportLimits/$(limitId);
    }

    function isAdmin() {
      return signedIn()
        && exists(userProfilePath(request.auth.uid))
        && get(userProfilePath(request.auth.uid)).data.role == "admin";
    }

    function validOptionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function validOptionalCloudinaryImageUrl(data) {
      return !data.keys().hasAny(["imageUrl"])
        || (data.imageUrl is string
          && data.imageUrl.size() <= 1000
          && data.imageUrl.matches("^https://res\\.cloudinary\\.com/dh0xm7zdj/image/upload/.*"));
    }

    function validOptionalCloudinaryPublicId(data) {
      return !data.keys().hasAny(["imagePublicId"])
        || (data.imagePublicId is string
          && data.imagePublicId.size() <= 255
          && data.imagePublicId.matches("^[A-Za-z0-9_./-]+$"));
    }

    function validOptionalCloudinaryPhotoUrl(data) {
      return !data.keys().hasAny(["photoUrl"])
        || (data.photoUrl is string
          && data.photoUrl.size() <= 1000
          && data.photoUrl.matches("^https://res\\.cloudinary\\.com/dh0xm7zdj/image/upload/.*"));
    }

    function validOptionalCloudinaryPhotoPublicId(data) {
      return !data.keys().hasAny(["photoPublicId"])
        || (data.photoPublicId is string
          && data.photoPublicId.size() <= 255
          && data.photoPublicId.matches("^[A-Za-z0-9_./-]+$"));
    }

    function validProfile(uid) {
      return request.resource.data.keys().hasAll([
          "uid",
          "email",
          "displayName",
          "role",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "role",
          "createdAt",
          "updatedAt",
          "photoUrl",
          "photoPublicId"
        ])
        && request.resource.data.uid == uid
        && request.resource.data.role == "citizen"
        && validOptionalString(request.resource.data.email, 254)
        && validOptionalString(request.resource.data.displayName, 80)
        && validOptionalCloudinaryPhotoUrl(request.resource.data)
        && validOptionalCloudinaryPhotoPublicId(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validStatus(status) {
      return status in ["submitted", "under-review", "in-progress", "resolved"];
    }

    function validCategory(category) {
      return category in [
        "pothole",
        "streetlight",
        "flooding",
        "garbage",
        "drainage",
        "illegal-dumping",
        "other"
      ];
    }

    function validDavaoRegionArea(area) {
      return area in [
        "Davao City",
        "Davao del Sur",
        "Davao Occidental",
        "Davao de Oro",
        "Davao del Norte",
        "Davao Oriental"
      ];
    }

    function validDavaoCoordinates(latitude, longitude) {
      return latitude is number
        && latitude >= 5.2
        && latitude <= 8.15
        && longitude is number
        && longitude >= 124.9
        && longitude <= 126.75;
    }

    function validReportLimitBase(data, uid, scope, maxReports, windowDuration) {
      return data.keys().hasAll([
          "uid",
          "scope",
          "windowStart",
          "count",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "uid",
          "scope",
          "windowStart",
          "count",
          "updatedAt"
        ])
        && data.uid == uid
        && data.scope == scope
        && data.windowStart is timestamp
        && data.windowStart <= request.time
        && data.windowStart >= request.time - windowDuration
        && data.count is int
        && data.count >= 1
        && data.count <= maxReports
        && data.updatedAt == request.time;
    }

    function validReportLimitCreate(uid, scope, maxReports, windowDuration) {
      return validReportLimitBase(request.resource.data, uid, scope, maxReports, windowDuration)
        && request.resource.data.count == 1;
    }

    function validReportLimitUpdate(uid, scope, maxReports, windowDuration) {
      return validReportLimitBase(request.resource.data, uid, scope, maxReports, windowDuration)
        && resource.data.uid == uid
        && resource.data.scope == scope
        && resource.data.windowStart is timestamp
        && resource.data.count is int
        && (
          (
            resource.data.windowStart >= request.time - windowDuration
            && request.resource.data.windowStart == resource.data.windowStart
            && request.resource.data.count == resource.data.count + 1
          )
          || (
            resource.data.windowStart < request.time - windowDuration
            && request.resource.data.count == 1
          )
        );
    }

    function validReportLimitAfterBase(uid, scope, maxReports, windowDuration) {
      return existsAfter(reportLimitPath(uid, scope))
        && validReportLimitBase(getAfter(reportLimitPath(uid, scope)).data, uid, scope, maxReports, windowDuration);
    }

    function validReportLimitAfterIncrement(uid, scope, maxReports, windowDuration) {
      return validReportLimitAfterBase(uid, scope, maxReports, windowDuration)
        && (
          (
            !exists(reportLimitPath(uid, scope))
            && getAfter(reportLimitPath(uid, scope)).data.count == 1
          )
          || (
            exists(reportLimitPath(uid, scope))
            && get(reportLimitPath(uid, scope)).data.windowStart >= request.time - windowDuration
            && getAfter(reportLimitPath(uid, scope)).data.windowStart ==
              get(reportLimitPath(uid, scope)).data.windowStart
            && getAfter(reportLimitPath(uid, scope)).data.count ==
              get(reportLimitPath(uid, scope)).data.count + 1
          )
          || (
            exists(reportLimitPath(uid, scope))
            && get(reportLimitPath(uid, scope)).data.windowStart < request.time - windowDuration
            && getAfter(reportLimitPath(uid, scope)).data.count == 1
          )
        );
    }

    function validReportCreateRateLimit() {
      return validReportLimitAfterIncrement(request.auth.uid, "hour", 5, duration.value(1, "h"))
        && validReportLimitAfterIncrement(request.auth.uid, "day", 20, duration.value(24, "h"));
    }

    function validReportData() {
      return request.resource.data.keys().hasAll([
          "title",
          "category",
          "description",
          "barangay",
          "latitude",
          "longitude",
          "status",
          "upvotes",
          "createdBy",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "title",
          "category",
          "description",
          "barangay",
          "latitude",
          "longitude",
          "status",
          "upvotes",
          "createdBy",
          "createdAt",
          "updatedAt",
          "imageUrl",
          "imagePublicId"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 5
        && request.resource.data.title.size() <= 120
        && validCategory(request.resource.data.category)
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.description.size() <= 800
        && request.resource.data.barangay is string
        && validDavaoRegionArea(request.resource.data.barangay)
        && validDavaoCoordinates(request.resource.data.latitude, request.resource.data.longitude)
        && request.resource.data.status == "submitted"
        && request.resource.data.upvotes == 0
        && request.resource.data.createdBy == request.auth.uid
        && validOptionalCloudinaryImageUrl(request.resource.data)
        && validOptionalCloudinaryPublicId(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validReportCreateRateLimit();
    }

    function validReportEditableFields() {
      return request.resource.data.title is string
        && request.resource.data.title.size() >= 5
        && request.resource.data.title.size() <= 120
        && validCategory(request.resource.data.category)
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.description.size() <= 800
        && request.resource.data.barangay is string
        && validDavaoRegionArea(request.resource.data.barangay)
        && validDavaoCoordinates(request.resource.data.latitude, request.resource.data.longitude)
        && request.resource.data.updatedAt == request.time
        // Immutable fields must remain unchanged (defense-in-depth alongside hasOnly diff check)
        && request.resource.data.status == resource.data.status
        && request.resource.data.upvotes == resource.data.upvotes
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validReportConfirmationCountUpdate(reportId) {
      return signedIn()
        && resource.data.createdBy != request.auth.uid
        && !exists(upvotePath(reportId, request.auth.uid))
        && getAfter(upvotePath(reportId, request.auth.uid)).data.reportId == reportId
        && getAfter(upvotePath(reportId, request.auth.uid)).data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "upvotes",
          "updatedAt"
        ])
        && request.resource.data.upvotes == resource.data.upvotes + 1
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if signedIn()
        && request.auth.uid == uid
        && validProfile(uid);
      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "displayName",
            "photoUrl",
            "photoPublicId",
            "updatedAt"
          ])
          && validOptionalString(request.resource.data.displayName, 80)
          && validOptionalCloudinaryPhotoUrl(request.resource.data)
          && validOptionalCloudinaryPhotoPublicId(request.resource.data)
          && request.resource.data.updatedAt == request.time);
      allow delete: if false;

      match /reportLimits/{limitId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn()
          && request.auth.uid == uid
          && (
            (limitId == "hour" && validReportLimitCreate(uid, "hour", 5, duration.value(1, "h")))
            || (limitId == "day" && validReportLimitCreate(uid, "day", 20, duration.value(24, "h")))
          );
        allow update: if signedIn()
          && request.auth.uid == uid
          && (
            (limitId == "hour" && validReportLimitUpdate(uid, "hour", 5, duration.value(1, "h")))
            || (limitId == "day" && validReportLimitUpdate(uid, "day", 20, duration.value(24, "h")))
          );
        allow delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if signedIn() && validReportData();
      allow update: if (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status",
            "updatedAt"
          ])
          && validStatus(request.resource.data.status)
          && request.resource.data.updatedAt == request.time)
        || (signedIn()
          && resource.data.createdBy == request.auth.uid
          && resource.data.status == "submitted"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "title",
            "category",
            "description",
            "barangay",
            "latitude",
            "longitude",
            "updatedAt"
          ])
          && validReportEditableFields())
        || validReportConfirmationCountUpdate(reportId);
      allow delete: if isAdmin()
        || (signedIn()
          && resource.data.createdBy == request.auth.uid
          && resource.data.status == "submitted");
    }

    match /statusLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll([
          "reportId",
          "status",
          "updatedBy",
          "createdAt"
        ])
        && request.resource.data.keys().hasOnly([
          "reportId",
          "status",
          "note",
          "updatedBy",
          "createdAt"
        ])
        && request.resource.data.reportId is string
        && validStatus(request.resource.data.status)
        && validOptionalString(request.resource.data.note, 500)
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /upvotes/{upvoteId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && upvoteId == request.resource.data.reportId + "_" + request.auth.uid
        && request.resource.data.keys().hasAll([
          "reportId",
          "userId",
          "createdAt"
        ])
        && request.resource.data.keys().hasOnly([
          "reportId",
          "userId",
          "createdAt"
        ])
        && request.resource.data.reportId is string
        && exists(reportPath(request.resource.data.reportId))
        && get(reportPath(request.resource.data.reportId)).data.createdBy != request.auth.uid
        && getAfter(reportPath(request.resource.data.reportId)).data.upvotes ==
          get(reportPath(request.resource.data.reportId)).data.upvotes + 1
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
